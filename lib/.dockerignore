# Node dependencies (we install inside Docker)
node_modules

# Next.js build output (Docker builds it)
.next

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files (never bake secrets into images)
.env
.env.*
!.env.example

# Git
.git
.gitignore

# Docker files themselves
Dockerfile
docker-compose.yml

# OS / editor junk
.DS_Store
Thumbs.db
.vscode
.idea

# Tests & docs (optional)
__tests__
coverage
docs

# CI / tooling artifacts
jenkins
.github

# Temporary files
tmp
temp
*.swp
